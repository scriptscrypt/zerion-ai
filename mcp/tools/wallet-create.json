{
  "name": "wallet-create",
  "description": "Create a new encrypted wallet with EVM and Solana addresses.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "name": {
        "type": "string",
        "description": "Name for the new wallet"
      }
    },
    "required": ["name"]
  },
  "cli": "zerion-cli wallet create --name {name}"
}
